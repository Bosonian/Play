<?xml version="1.0" encoding="utf-8"?>
<!-- Widgets increment (Runway 0.10.0): the Prüfung home-screen widget's
     layout. Three plain TextViews, no progress bars or icons — same "plain
     numbers, no bars" reasoning as the app's own topic list
     (RUNWAY_PRUFUNG_PLAN.md §4.1). Rendered by
     PruefungWidgetProvider.java; colours for widget_line1 are set
     programmatically there (calm/tight/late), everything else here is
     static.

     m1: the android:text values below are visible ONLY in the widget
     picker's preview (no previewImage is set — see widget_pruefung_info.xml
     — so the picker falls back to rendering this initialLayout as-is).
     PruefungWidgetProvider.onUpdate ALWAYS overwrites every one of these
     TextViews the moment the widget is actually placed on a home screen;
     nothing below is ever shown to Deepak on a real, placed widget. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="start|center_vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_line1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#F1F5F9"
        android:maxLines="1"
        android:text="Ready by 14 Dec" />

    <TextView
        android:id="@+id/widget_line2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="13sp"
        android:textColor="#94A3B8"
        android:maxLines="1"
        android:text="Exam Nov 2026" />

    <TextView
        android:id="@+id/widget_line3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="13sp"
        android:textColor="#94A3B8"
        android:maxLines="1"
        android:text="This week 1.5 of 6.5 h" />

</LinearLayout>
