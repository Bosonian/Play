<?xml version="1.0" encoding="utf-8"?>
<!-- Widgets increment: metadata for the Prüfung widget
     (PruefungWidgetProvider.java), referenced from the <receiver>
     meta-data in AndroidManifest.xml.

     minWidth/minHeight: sized for a nominal 3-cell-wide, 1-cell-tall
     placement. The standard cell-size formula ((70 × n) − 30 dp) gives
     180dp × 40dp for 3×1, but 40dp is tight for three stacked text lines
     (18sp + 13sp + 13sp, plus padding) — bumped minHeight to 64dp so all
     three lines have room to render without clipping on a real launcher
     grid, which is usually a bit more generous than the strict formula
     anyway. A judgment call, not a spec number — untested against a real
     launcher (no Android SDK/emulator available in this environment; see
     the increment's own "CI will prove" list).

     updatePeriodMillis: 6 hours. The widget's whole display is a 1:1 date
     slide (today + offsetDays) off data that itself only changes when
     Deepak logs a sprint or edits the exam/topics — none of which need a
     redraw faster than a few times a day just to keep "today" current;
     refreshWidgets() (src/native/widgets.ts) already pushes an immediate
     redraw the moment any of that actually changes.

     previewImage intentionally omitted (increment brief: "acceptable;
     note it") — the widget picker falls back to rendering the
     initialLayout itself when none is set, which is an accurate preview
     for a widget this simple anyway. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="64dp"
    android:updatePeriodMillis="21600000"
    android:initialLayout="@layout/widget_pruefung"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
