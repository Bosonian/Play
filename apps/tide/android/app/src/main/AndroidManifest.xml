<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Health Connect bridge increment (0.3.0): Health Connect's own
                 permission-request screen offers a "See how your data is
                 used" / privacy-rationale link, and requires SOME activity
                 in this app to answer this exact intent action for that
                 link to work — this is Health Connect's own documented
                 contract (androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE),
                 not optional boilerplate. Routed at MainActivity itself
                 rather than a dedicated privacy-policy screen: Tide is a
                 sideloaded, single-user personal app with no Play Store
                 listing (see README.md's Signing section) and no privacy-
                 policy page of its own to link to — this satisfies Health
                 Connect's contract (an activity exists to receive the
                 intent) without fabricating a policy page that would say
                 nothing beyond what CLAUDE.md's "local-first, no accounts"
                 framing already states. Landing on the normal app (Home)
                 when tapped is an accepted, honest simplification, not a
                 broken link. UNVERIFIED: whether Health Connect's real
                 permission screen actually surfaces/requires this link for
                 an app of Tide's shape — flagged for real-device testing
                 alongside the rest of this increment's native surface. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Health Connect bridge increment (0.3.0) — read-only, TIDE_PLAN.md §3.
         No WRITE_* permission anywhere in this list: Tide only ever reads
         from Health Connect, it never writes a record back into it. -->
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />

    <!-- Android 11+ (API 30+) hides package visibility by default —
         `isAvailable()`/HealthConnectPlugin.kt's SDK-status check and the
         permission-request flow both need to see whether the Health Connect
         app is actually installed, which requires declaring it here even
         though Tide never launches it by package name directly (the
         connect-client library does that internally). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>
</manifest>
